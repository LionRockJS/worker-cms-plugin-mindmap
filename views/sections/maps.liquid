<div class="flex items-center justify-between gap-4 mb-4">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Mind maps</h1>
    <p class="mt-1 text-sm text-gray-500">Each mind map is a CMS page. Open one to edit it visually.</p>
  </div>
</div>
{% if flash != blank %}<p class="mb-4 rounded-lg bg-gray-50 border border-gray-200 px-4 py-3 text-sm text-gray-700">{{ flash }}</p>{% endif %}
{% if canEdit %}
<form method="post" action="{{ newAction }}" class="flex flex-wrap items-center gap-2 mb-4">
  <input name="name" required maxlength="200" placeholder="New mind map name" class="px-3 py-2 border border-gray-300 rounded-lg text-sm" style="width:20rem;max-width:100%">
  <button type="submit" class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border border-transparent bg-indigo-600 text-white hover:bg-indigo-700 cursor-pointer">Create mind map</button>
</form>
{% endif %}
<div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-x-auto">
  <table class="w-full text-left text-sm">
    <thead class="bg-gray-50 border-b border-gray-200">
      <tr>
        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Name</th>
        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Nodes</th>
        <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Updated</th>
        <th class="px-6 py-3"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      {% for map in maps %}
        <tr>
          <td class="px-6 py-3 text-sm text-gray-700"><a class="text-indigo-600 font-medium hover:text-indigo-800" href="{{ map.editHref }}">{{ map.name }}</a></td>
          <td class="px-6 py-3 text-sm text-gray-500">{{ map.nodeCount }}</td>
          <td class="px-6 py-3 text-sm text-gray-500">{{ map.updated }}</td>
          <td class="px-6 py-3 text-right whitespace-nowrap">
            {% if map.deleteAction != blank %}
            <form method="post" action="{{ map.deleteAction }}" data-confirm="Delete this mind map? This cannot be undone." class="inline-block">
              <button type="submit" class="border-0 bg-transparent p-0 text-xs font-semibold text-red-600 cursor-pointer hover:text-red-700">Delete</button>
            </form>
            {% endif %}
          </td>
        </tr>
      {% else %}
        <tr><td colspan="4" class="px-6 py-10 text-center text-sm text-gray-400">No mind maps yet.</td></tr>
      {% endfor %}
    </tbody>
  </table>
</div>
