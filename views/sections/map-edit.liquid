<div class="mb-3">
  <a class="inline-block text-xs text-gray-500 hover:text-indigo-700" href="{{ backHref }}">&larr; Mind maps</a>
</div>
{% if flash != blank %}<p data-mm-flash class="mb-4 rounded-lg bg-gray-50 border border-gray-200 px-4 py-3 text-sm text-gray-700">{{ flash }}</p>{% endif %}
{% for error in errors %}<p class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">{{ error }}</p>{% endfor %}

<form id="mindmap-form" method="post" action="{{ action }}">
  {% if cmsEditor %}
  <input type="hidden" name="page_type" value="{{ pageType }}">
  <input type="hidden" name="weight" value="{{ weight }}">
  <input type="hidden" name="start" value="{{ start }}">
  <input type="hidden" name="end" value="{{ end }}">
  <input type="hidden" name="timezone" value="{{ timezone }}">
  <input type="hidden" name="editors" value="{{ editors }}">
  <input type="hidden" name="return_to" value="{{ backHref }}">
  <div data-mm-cms-fields hidden>
    {% for field in cmsFields %}<input type="hidden" name="{{ field.name }}" value="{{ field.value }}">{% endfor %}
  </div>
  {% endif %}
  <fieldset{% if readOnly %} disabled{% endif %} style="border:0;padding:0;margin:0;min-width:0">
    {%- comment -%} Inline Page Identity Header: editable title + slash-prefixed slug. {%- endcomment -%}
    <div class="mb-4">
      <input id="mindmap-name" class="block w-full border-0 p-0 bg-transparent text-2xl font-bold text-gray-900 focus:outline-none focus:ring-0" name="name" value="{{ name }}" required maxlength="200" autocomplete="off" placeholder="Mind map name">
      {% if cmsEditor %}<div class="text-gray-500 font-mono text-xs mt-1 w-full flex">/<input id="mindmap-slug" class="font-mono text-xs border-0 w-full bg-transparent focus:outline-none focus:ring-0" name="slug" value="{{ slug }}" required autocomplete="off" placeholder="slug"></div>{% endif %}
      {% unless readOnly %}
      <div class="mt-2 flex flex-wrap items-center gap-2">
        <p class="text-sm text-gray-500">Tab adds a child, Enter adds a sibling, double-click edits text and translations, Delete removes a branch. Drag a node onto another node to move it.</p>
        <span data-mm-dirty hidden class="text-xs font-semibold text-gray-500">Unsaved changes</span>
      </div>
      {% endunless %}
    </div>

    <div data-mindmap data-mm-language="{{ language }}"{% if readOnly %} data-readonly="1"{% endif %} class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden mb-4">
      <div data-mm-toolbar hidden class="flex flex-wrap items-center gap-2 px-4 py-3 border-b border-gray-200">
        <span class="flex-1"></span>
        <button type="button" data-mm-zoom-out title="Zoom out" aria-label="Zoom out" class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border bg-white text-gray-700 border-gray-300 hover:bg-gray-50 cursor-pointer">&minus;</button>
        <button type="button" data-mm-zoom-fit class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border bg-white text-gray-700 border-gray-300 hover:bg-gray-50 cursor-pointer">Fit</button>
        <button type="button" data-mm-zoom-in title="Zoom in" aria-label="Zoom in" class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border bg-white text-gray-700 border-gray-300 hover:bg-gray-50 cursor-pointer">+</button>
      </div>
      <div data-mm-canvas hidden class="relative" style="height:65vh;min-height:24rem"></div>
      <div data-mm-fallback class="p-6">
        <span class="block text-sm text-gray-700 mb-1">Mind map data (JSON)</span>
        <p class="mt-1 text-sm text-gray-500">The visual editor loads from this plugin's approved JavaScript asset. Until then you can edit the raw document: every node is an object with "id", "text", "parent", and optional "displayText" values by language; the root node has "parent": null. Nodes are stored as page items, so the native page editor edits them too.</p>
        <textarea name="data" data-mm-source rows="16" spellcheck="false" class="mt-2 block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm font-mono">{{ data }}</textarea>
      </div>
    </div>
  </fieldset>
  {% unless readOnly %}
  <div class="flex min-w-0 flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center sticky bottom-4">
    <button type="submit" data-mm-save{% if fallbackAction != blank %} formaction="{{ fallbackAction }}"{% endif %}
            class="w-full px-6 py-2 bg-indigo-600 text-white text-sm font-semibold rounded-lg hover:bg-indigo-700 transition-colors shadow-sm sm:w-auto">
      {{ saveLabel }}
    </button>
    <a href="{{ backHref }}" class="w-full px-6 py-2 text-center bg-white text-gray-700 text-sm font-semibold rounded-lg border border-gray-300 hover:bg-gray-50 transition-colors sm:w-auto">
      Cancel
    </a>
    {% if deleteAction != blank %}
    <button type="submit" form="mindmap-delete-form" formnovalidate
            class="w-full px-6 py-2 bg-red-600 text-white text-sm font-semibold rounded-lg hover:bg-red-700 transition-colors shadow-sm sm:ml-auto sm:w-auto">
      {{ deleteLabel }}
    </button>
    {% endif %}
  </div>
  {% endunless %}
</form>

{% if deleteAction != blank %}
<form id="mindmap-delete-form" method="post" action="{{ deleteAction }}" data-confirm="{{ deleteConfirm }}"></form>
{% endif %}

<script src="{{ assetHref }}" defer></script>
