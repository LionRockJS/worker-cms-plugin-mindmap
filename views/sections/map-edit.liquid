<div class="flex items-center justify-between gap-4 mb-4">
  <div>
    <a class="inline-block text-xs text-gray-500 mb-1 hover:text-indigo-700" href="{{ backHref }}">&larr; Mind maps</a>
    <h1 class="text-2xl font-bold text-gray-900">{{ title }}</h1>
    {% unless readOnly %}<p class="mt-1 text-sm text-gray-500">Tab adds a child, Enter adds a sibling, double-click renames, Delete removes a branch. Drag a node onto another node to move it.</p>{% endunless %}
  </div>
  {% if pageEditHref != blank %}<a class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border bg-white text-gray-700 border-gray-300 hover:bg-gray-50 whitespace-nowrap" href="{{ pageEditHref }}">Open in page editor</a>{% endif %}
</div>
{% if flash != blank %}<p class="mb-4 rounded-lg bg-gray-50 border border-gray-200 px-4 py-3 text-sm text-gray-700">{{ flash }}</p>{% endif %}
{% for error in errors %}<p class="mb-4 rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-sm text-red-700">{{ error }}</p>{% endfor %}

<form method="post" action="{{ action }}">
  <fieldset{% if readOnly %} disabled{% endif %} style="border:0;padding:0;margin:0;min-width:0">
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-4">
      <div class="flex flex-wrap items-center gap-2">
        <label class="flex-1" style="min-width:16rem">
          <span class="block text-sm text-gray-700 mb-1">Name</span>
          <input name="name" value="{{ name }}" required maxlength="200" class="block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm">
        </label>
        {% unless readOnly %}
        <span data-mm-dirty hidden class="text-xs font-semibold text-gray-500">Unsaved changes</span>
        <button type="submit" class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border border-transparent bg-indigo-600 text-white hover:bg-indigo-700 cursor-pointer">Save</button>
        {% endunless %}
      </div>
    </div>

    <div data-mindmap{% if readOnly %} data-readonly="1"{% endif %} class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden mb-4">
      <div data-mm-toolbar hidden class="flex flex-wrap items-center gap-2 px-4 py-3 border-b border-gray-200">
        {% unless readOnly %}
        <button type="button" data-mm-add-child class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border bg-white text-gray-700 border-gray-300 hover:bg-gray-50 cursor-pointer">Add child</button>
        <button type="button" data-mm-add-sibling class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border bg-white text-gray-700 border-gray-300 hover:bg-gray-50 cursor-pointer">Add sibling</button>
        <button type="button" data-mm-rename class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border bg-white text-gray-700 border-gray-300 hover:bg-gray-50 cursor-pointer">Rename</button>
        <button type="button" data-mm-delete class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border bg-white text-red-600 border-gray-300 hover:bg-red-50 cursor-pointer">Delete node</button>
        {% endunless %}
        <span class="flex-1"></span>
        <button type="button" data-mm-zoom-out title="Zoom out" aria-label="Zoom out" class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border bg-white text-gray-700 border-gray-300 hover:bg-gray-50 cursor-pointer">&minus;</button>
        <button type="button" data-mm-zoom-fit class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border bg-white text-gray-700 border-gray-300 hover:bg-gray-50 cursor-pointer">Fit</button>
        <button type="button" data-mm-zoom-in title="Zoom in" aria-label="Zoom in" class="inline-block px-4 py-2 rounded-lg text-sm font-semibold border bg-white text-gray-700 border-gray-300 hover:bg-gray-50 cursor-pointer">+</button>
      </div>
      <div data-mm-canvas hidden class="relative" style="height:65vh;min-height:24rem"></div>
      <div data-mm-fallback class="p-6">
        <span class="block text-sm text-gray-700 mb-1">Mind map data (JSON)</span>
        <p class="mt-1 text-sm text-gray-500">The visual editor loads from this plugin's approved JavaScript asset. Until then you can edit the raw document: every node is an object with "id", "text" and "parent"; the root node has "parent": null. Nodes are stored as page items, so the native page editor edits them too.</p>
        <textarea name="data" data-mm-source rows="16" spellcheck="false" class="mt-2 block w-full px-3 py-2 border border-gray-300 rounded-lg text-sm font-mono">{{ data }}</textarea>
      </div>
    </div>
  </fieldset>
</form>

{% if deleteAction != blank %}
<form method="post" action="{{ deleteAction }}" data-confirm="Delete this mind map? This cannot be undone.">
  <button type="submit" class="border-0 bg-transparent p-0 text-xs font-semibold text-red-600 cursor-pointer hover:text-red-700">Delete mind map</button>
</form>
{% endif %}

<script src="{{ assetHref }}" defer></script>
